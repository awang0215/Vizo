{
  "name": "vizo",
  "version": "1.0.4",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "description": "Vizo - AI 生图 / 改图桌面工具",
  "author": "阿旺",
  "scripts": {
    "setup": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ npm install",
    "dev": "cross-env ELECTRON_USER_DATA=./.electron-user-data electron-vite dev",
    "build": "electron-vite build",
    "build:win": "node scripts/generate-icon.js && npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --publish never --config electron-builder.config.cjs",
    "build:win:dir": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --dir --publish never --config electron-builder.config.cjs",
    "build:win:signed": "npm run build && electron-builder --win --publish never --config electron-builder.config.cjs",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "electron-updater": "^6.3.9",
    "https-proxy-agent": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "cross-env": "^7.0.3",
    "electron": "^28.1.0",
    "electron-builder": "24.6.3",
    "electron-vite": "^2.0.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
